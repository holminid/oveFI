---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
  image?: string;
  lang?: string;
  noindex?: boolean;
  hideHeader?: boolean;
  hideNav?: boolean;
  hideFooter?: boolean;
  logoSrc?: string;
  logoAlt?: string;
}
const {
  title = 'ove.fi',
  description = 'Artist site',
  image,
  lang = 'en',
  noindex = false,
  hideHeader = false,
  hideNav = false,
  hideFooter = false,
  logoSrc = '/images/ove-logo-exact.png',
  logoAlt = 'Ove geometric logo'
} = Astro.props as Props;
const pathname = Astro.url.pathname;
const isAbout = pathname === '/about' || pathname === '/about/';
const isWork = pathname === '/works' || pathname === '/works/' || pathname.startsWith('/works/');
const site = Astro.site ?? new URL('https://ove.fi');
const canonical = new URL(Astro.url?.pathname ?? '/', site);
const ogImageAbs = image ? new URL(image, site).href : undefined;
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="data:," />
    <link rel="canonical" href={canonical.href} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ove.fi" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogImageAbs && <meta property="og:image" content={ogImageAbs} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageAbs && <meta name="twitter:image" content={ogImageAbs} />}
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 bg-brandYellow text-black px-3 py-1 rounded">Skip to content</a>
    {!hideHeader && (
      <header class="container site-header">
        <a href="/" class="site-mark" aria-label="Home">
          <span class="site-mark__frame">
            <img src={logoSrc} alt={logoAlt} class="site-mark__image" />
          </span>
        </a>
        {!hideNav && (
          <nav class="site-nav meta" aria-label="Main">
            <a href="/about" aria-current={isAbout ? 'page' : undefined}>About</a>
            <a href="/works" aria-current={isWork ? 'page' : undefined}>Work</a>
            <a href="mailto:ove@ove.fi" title="mailto: ove@ove.fi">Contact</a>
          </nav>
        )}
      </header>
    )}
    <main id="main" class="container pb-16">
      <slot />
    </main>
    {!hideFooter && (
      <footer class="container site-footer">
        <slot name="footer-extra" />
        {!hideNav && (
          <nav class="site-footer__nav meta" aria-label="Footer">
            <a href="/about" aria-current={isAbout ? 'page' : undefined}>About</a>
            <a href="/works" aria-current={isWork ? 'page' : undefined}>Work</a>
            <a href="mailto:ove@ove.fi" title="mailto: ove@ove.fi">Contact</a>
          </nav>
        )}
        <p class="site-footer__copy text-sm" style="color: var(--muted);">
          Copyright © 2026 Ove Holmqvist and Associates. All Rights Reserved.
        </p>
      </footer>
    )}
    <style is:global>
      @import '@fontsource/inter/400.css';
      @import '@fontsource/inter/500.css';
      @import '@fontsource/inter/700.css';

      .site-footer {
        display: grid;
        justify-items: center;
        gap: 0.9rem;
        padding-top: 3rem;
        padding-bottom: 3rem;
        text-align: center;
      }

      .site-footer__nav {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1.15rem;
        transform: translateX(0.5rem);
        font-size: 0.92rem;
      }

      .site-footer__nav a {
        color: inherit;
        text-decoration: none;
      }

      .site-footer__nav a:hover,
      .site-footer__nav a:focus-visible,
      .site-footer__nav a[aria-current='page'] {
        text-decoration-line: underline;
        text-decoration-style: dotted;
        text-decoration-thickness: 1px;
        text-underline-offset: 0.15em;
      }

      .site-footer__copy {
        margin: 0;
        font-size: 0.64rem;
        line-height: 1.5;
        letter-spacing: 0.02em;
        text-transform: none;
      }

      @media (max-width: 640px) {
        .site-footer__nav {
          flex-wrap: wrap;
          transform: none;
        }
      }
    </style>
  </body>
</html>
