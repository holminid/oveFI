---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Video from '@/components/Video.astro';
import YouTube from '@/components/YouTube.astro';
import { getCollection } from 'astro:content';

const defaultSlug = 'triadic-mutualism';
const selectedSlugs = [
  'triadic-mutualism',
  'chimerik-improvised-performance-unity-consciousness-festival',
  'interactive-soundwalk-bc-ai-future-proof-creatives-vancouver',
  'aerialist-ilona-j-ntti-edu-dutch-design-week-2020',
  'fundaci-n-espacio-creativo-interactive-music-panama',
  'interactive-folk-music-creative-europe-c-dare-bidf',
  'holonic-dance-sound-synthesis-dmx-lighting-stage-effects',
  'adaptive-patch-for-a-public-artwork-proposal'
];
const hiddenListSlugs = new Set([
  'beddit',
  'fundaci-n-espacio-creativo-second-clip-panama',
  'holonic-dance-sound-synthesis-dmx-lighting-stage-effects',
  'first-rehearsal-with-marina-tsougrianis-orbit-princess',
  'gesture-posture-controlled-wilderness-setup-british-columbia',
  'lockdown-composition-geospatial-data-mappings',
  'posture-gesture-augmented-electroacoustic-lockdown-performance'
]);

const works = (await getCollection('works')).sort((a, b) => {
  const aOrder = selectedSlugs.indexOf(a.slug);
  const bOrder = selectedSlugs.indexOf(b.slug);

  if (aOrder !== -1 || bOrder !== -1) {
    if (aOrder === -1) return 1;
    if (bOrder === -1) return -1;
    return aOrder - bOrder;
  }

  return a.data.date < b.data.date ? 1 : -1;
});

const fecSecondClip = works
  .find((work) => work.slug === 'fundaci-n-espacio-creativo-second-clip-panama')
  ?.data.externalVideos.find((video) => video.kind === 'youtube' && video.id);

const triadicViewerCopy = `This piece was created in collaboration with Ezequiel Peralta for PXR Conference 2026. Shown simultaneously at VIVO Media Arts in Vancouver, BC, Toronto and Kingston, Ontario, it is a networked participatory audiovisual environment in which collective movement becomes the driving force of a shared musical and ecological system. Visitors encounter a luminous field on the floor that appears responsive but not didactic. As they move, pause, follow, gather, or disperse, they begin to perceive that the environment is listening to qualities of behaviour rather than simple triggers. Musical changes emerge from their collective activity, while smaller zones allow them to engage with remote sites, summon exchanges, or influence other communities. Over time, the piece reveals itself as a social instrument and an ecological score, an emergent multi-agent system whose local and global states are continuously negotiated through motion, attention, exchange, and co-presence.

Across multiple sites, geographically distributed audiences can influence one another through designated portal zones that connect remote locations in real time. These cross-site exchanges are framed through bioinformed concepts such as migration, diversity, metabolic balance, flock health, and resource circulation. When groups become active, coordinated, or mutually responsive, the system produces events such as tokens, exchanges, or energetic shifts that alter both the local visual field and the evolving musical form.

The project sits at the intersection of participatory installation, embodied sonification, social choreography, and systems art. It proposes music not as a fixed composition, but as an emergent property of collective behavior. The audience does not simply activate content; it enters into a reciprocal relation with a dynamic environment that listens, interprets, and responds at the scale of both the individual and the group.

Its telematic structure extends the work beyond a single site, allowing audiences in different cities to encounter one another as abstract presences inside a shared ecological-musical world. This creates a distributed public made legible through movement, rhythm, and changing systemic conditions rather than language alone. The work therefore offers a live model of interdependence: between bodies and sound, between local action and remote consequence, and between individual agency and collective form.`;

const stripExcerpt = (value: string) =>
  value
    .replace(/^import\s.+$/gm, '')
    .replace(/<[^>]+>/g, ' ')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/[`*_>#-]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();

const preparedWorks = works.map((work) => {
  const isMusicForBuildings = work.slug === 'adaptive-patch-for-a-public-artwork-proposal';
  const isTriadic = work.slug === 'triadic-mutualism';
  const isSoundwalk = work.slug === 'interactive-soundwalk-bc-ai-future-proof-creatives-vancouver';
  const isFecAlgo = work.slug === 'fundaci-n-espacio-creativo-interactive-music-panama';
  const copySource = isMusicForBuildings
    ? 'In this piece, GPS coordinates are used as musical events and modifiers. This marks my first foray into spatial computing, courtesy of Holonic\'s partnership with Bose. The Bose AR system enabled true, non-optical positioning and Auditory AR, in this case gaze-controlled spatial music. The old Coast Plaza Hotel seems to be haunted by John Foxx’s CR-78.'
    : isTriadic
      ? triadicViewerCopy
    : isSoundwalk
      ? (work.body?.trim() || work.data.summary || '').replace(/\n!\[[^\]]*\]\([^)]+\)\n/g, '\n')
      : work.body?.trim() || work.data.summary || '';
  const rawCopyParagraphs = copySource
    .split(/\n\s*\n/)
    .map((paragraph) => stripExcerpt(paragraph))
    .filter(Boolean);
  const copyParagraphs = isFecAlgo ? rawCopyParagraphs.slice(0, -1) : rawCopyParagraphs;
  const firstExternalVideo = isMusicForBuildings
    ? { kind: 'youtube', id: 'wDzCtorUS2A', title: 'Augmented Aural Reality: Music For Buildings pt. 1', aspect: '16:9' as const }
    : work.data.externalVideos.find((video) => video.kind === 'youtube' && video.id);
  const firstVideo = work.data.videos[0];

  return {
    work,
    copyParagraphs,
    firstExternalVideo,
    firstVideo,
    secondaryExternalVideo:
      isFecAlgo ? fecSecondClip ?? null : null,
    postSecondaryExternalVideoParagraph: isFecAlgo ? rawCopyParagraphs.at(-1) ?? null : null,
    inlineImage:
      isSoundwalk
        ? {
            src: '/works/interactive-soundwalk-bc-ai-future-proof-creatives-vancouver/sound-walk_h.jpg',
            alt: 'Socio-spatial soundwalk image',
            insertAfterParagraph: 3
          }
        : null,
    placeholderImage: isTriadic
      ? {
          src: '/works/triadic-mutualism-pxr-conference/triadic-1.jpg',
          alt: 'Triadic Mutualism installation view'
        }
      : null
  };
});

const selectedPreparedWorks = selectedSlugs
  .map((slug) => preparedWorks.find(({ work }) => work.slug === slug))
  .filter(Boolean);
const defaultWork = selectedPreparedWorks.find(({ work }) => work.slug === defaultSlug)?.work ?? selectedPreparedWorks[0]?.work ?? works[0];
const listedWorks = selectedPreparedWorks.filter(({ work }) => !hiddenListSlugs.has(work.slug));
const bedditWork = preparedWorks.find(({ work }) => work.slug === 'beddit');
const bedditLeadParagraph = bedditWork?.copyParagraphs[0] ?? '';
const bedditTailParagraphs = bedditWork?.copyParagraphs.slice(1) ?? [];
const bedditLeadMarker = 'My work for Beddit included';
const [bedditLeadIntro, bedditLeadFollowUp] = bedditLeadParagraph.includes(bedditLeadMarker)
  ? [
      bedditLeadParagraph.slice(0, bedditLeadParagraph.indexOf(bedditLeadMarker)).trim(),
      bedditLeadParagraph.slice(bedditLeadParagraph.indexOf(bedditLeadMarker)).trim()
    ]
  : [bedditLeadParagraph, ''];

const displayTitleBySlug = new Map([
  ['triadic-mutualism', 'Triadic Mutualism - Intercity Synchronicity'],
  ['chimerik-improvised-performance-unity-consciousness-festival', 'Biomechanical Duet'],
  ['interactive-soundwalk-bc-ai-future-proof-creatives-vancouver', 'Socio-Spatial Computing for Soundwalks'],
  ['fundaci-n-espacio-creativo-interactive-music-panama', 'F.E.C. ALGO Project'],
  ['interactive-folk-music-creative-europe-c-dare-bidf', 'Vibes #5: Interactive Choreography and Folk Music'],
  ['aerialist-ilona-j-ntti-edu-dutch-design-week-2020', 'Office Intervention @ Dutch Design Week'],
  ['holonic-dance-sound-synthesis-dmx-lighting-stage-effects', 'Dance performance by Anna Serra at Hangar.org in Barcelona'],
  ['adaptive-patch-for-a-public-artwork-proposal', 'Augmented Aural Reality: Music For Buildings pt. 1']
]);

const getDisplayTitle = (slug: string, fallback: string) => displayTitleBySlug.get(slug) ?? fallback;
---

<BaseLayout title="Works — ove.fi" description="Selected work">
  <section class="works-page">
    <div class="prose-ove works-section-heading works-section-heading--selected">
      <h2 class="text-2xl mb-0">Selected works</h2>
    </div>

    <div class="works-shell">
      <div class="works-main">
        <section class="card works-section">
          <div class="works-viewer">
            {selectedPreparedWorks.map(({ work, copyParagraphs, firstExternalVideo, firstVideo, secondaryExternalVideo, postSecondaryExternalVideoParagraph, inlineImage, placeholderImage }) => {
              const meta = [work.data.date, work.data.location].filter(Boolean).join(' · ');

              return (
                <article
                  class:list={['work-panel', { 'is-active': work.slug === defaultWork.slug }]}
                  data-work-panel
                  data-slug={work.slug}
                  hidden={work.slug !== defaultWork.slug}
                >
                  <div class="viewer-frame">
                    {firstExternalVideo ? (
                      <YouTube id={firstExternalVideo.id} title={firstExternalVideo.title ?? work.data.title} aspect={firstExternalVideo.aspect} />
                    ) : firstVideo ? (
                      <Video src={firstVideo.src} poster={firstVideo.poster} aspect={firstVideo.aspect} captions={firstVideo.captions} />
                    ) : placeholderImage ? (
                      <img
                        src={placeholderImage.src}
                        width="4032"
                        height="3024"
                        alt={placeholderImage.alt}
                        class="viewer-frame-image"
                      />
                    ) : (
                      <div class="placeholder-panel">Documentation in progress.</div>
                    )}
                  </div>

                  <div class="mt-5 prose-ove work-panel-copy">
                    <h1 class="text-2xl mb-2">{getDisplayTitle(work.slug, work.data.title)}</h1>
                    {meta && (
                      <p class="meta" style="color: var(--muted);">
                        {meta}
                      </p>
                    )}
                    {copyParagraphs.map((paragraph, index) => (
                      <>
                        <p class:list={['work-panel-paragraph', {
                          'work-panel-paragraph--first': index === 0,
                          'work-panel-paragraph--credits': paragraph.startsWith('Credits:')
                        }]}>
                          {paragraph}
                        </p>
                        {inlineImage && index === inlineImage.insertAfterParagraph && (
                          <figure class="work-panel-inline-image">
                            <img
                              src={inlineImage.src}
                              width="1800"
                              height="1013"
                              alt={inlineImage.alt}
                              class="work-panel-inline-image-element"
                            />
                          </figure>
                        )}
                      </>
                    ))}
                    {secondaryExternalVideo && (
                      <div class="work-panel-inline-video">
                        <YouTube
                          id={secondaryExternalVideo.id}
                          title={secondaryExternalVideo.title ?? `${work.data.title} additional documentation`}
                          aspect={secondaryExternalVideo.aspect}
                        />
                      </div>
                    )}
                    {postSecondaryExternalVideoParagraph && (
                      <p class="work-panel-paragraph work-panel-paragraph--after-inline-video">
                        {postSecondaryExternalVideoParagraph}
                      </p>
                    )}
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      </div>

      <aside class="works-sidebar-stack">
        <section class="card works-list-panel">
          <h2 class="meta works-list-heading">Video</h2>
          <ul class="works-list" role="list">
            {listedWorks.map(({ work }) => (
              <li>
                <a
                  class:list={['work-link', { 'is-active': work.slug === defaultWork.slug }]}
                  href={`/works?w=${work.slug}`}
                  data-work-link
                  data-slug={work.slug}
                >
                  <span>{getDisplayTitle(work.slug, work.data.title)}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      </aside>
    </div>

    <div class="works-lower">
      <section id="design" class="card works-section works-section--full works-section--design">
        <div class="prose-ove design-section-intro">
          <h2 class="text-2xl mb-3">Design</h2>
          <p class="max-w-4xl">I design and build experiential systems that combine audiovisual and physical interactions, with an emphasis on participatory experiences for audiences in cultural and applied contexts. I typically support projects from concept development through production.</p>
          <p class="max-w-4xl design-section-intro__followup">Case studies include concept design and branding for Telharmonium Labs and Holonic Systems, sonic interaction design, prototype design and event design for Beddit, as well as design of infographics and institutional cartography for the University of Tampere and the Academy of Finland.</p>
        </div>

        <div class="design-case-grid">
          <article class="design-case-card design-case-card--with-image">
            <figure class="design-case-media design-case-media--logo">
              <img
                src="/design/telharmonic-logo.jpg"
                width="1440"
                height="1080"
                alt="Telharmonium Labs logo"
                class="design-case-image"
              />
            </figure>
            <div class="prose-ove">
              <h3 class="text-xl mb-2">Telharmonium Labs, Inc.</h3>
              <p>
                Telharmonium Labs develops input- and output-agnostic music systems that compose in real time from structural and perceptual models. The system delivers deterministic, expressive, and explainable scores in any definable musical form while offering a controlled and auditable alternative to black-box generation of generic audio.
                <br /><br />
                The Telharmonium Composer is a rule-driven music engine built on symbolic representations of musical structure. It adapts to context and personal profiles, supports both linear and interactive composition and operates without need for custom model training.
                <br /><br />
                The Telharmonium musical world model defines music as enacted temporal narrative and an emergent system state.
              </p>
              <p class="design-case-link-row"><a href="https://www.telharmonium.ca" class="design-case-link">www.telharmonium.ca</a></p>
            </div>
          </article>

          <article class="design-case-card design-case-card--holonic">
            <div class="design-case-header design-case-header--with-logo">
              <div class="prose-ove">
                <h3 class="text-xl mb-2">Holonic Systems</h3>
                <p>Holonic Systems develops adaptive music systems for sonic placemaking, social musical communication, and responsive public and performance contexts. Through biosensors, physical computing, geospatial data, and mobile systems, this work explored how music could become contextually relevant, biologically and perceptually grounded, and situated in everyday life. It formed the basis for projects involving movement, biosignals, synthesis, lighting, and participatory scoring.</p>
              </div>
              <figure class="design-case-side-figure">
                <img
                  src="/design/holonic-logo.png"
                  width="1452"
                  height="846"
                  alt="Holonic Systems logo"
                  class="design-case-side-image"
                />
              </figure>
            </div>
            <div class="design-case-media-sequence">
              <figure class="design-case-media design-case-media--holonic-principles design-case-media--panel">
                <img
                  src="/design/holonic-operating-principles.png"
                  width="1452"
                  height="846"
                  alt="Holonic Systems operating principles diagram"
                  class="design-case-image"
                />
              </figure>
            </div>
            <section class="design-case-segment">
              <div class="prose-ove">
                <h4 class="text-lg mb-2">Holon</h4>
                <p>Holon is a zero-UI consumer demo of Holonic Systems’ platform for B2B clients. It showcases the Holonic backend for musical ubiquitous computing. Holon supports embedded audio engines, including Pure Data and miRack (iOS port of VCV Rack, exclusively licensed from mifki).</p>
                <p class="design-case-paragraph-gap">The Holon project not only challenges the visual bias in technology and urban design but also foregrounds the often under-appreciated role of sound and music in shaping human experience. Holon contributes to a broader discourse on sensory equity and on the importance of designing spaces and technologies that honour our evolutionary heritage and the full spectrum of human perception. Holon was nominated for the Music Cities 2025 Awards and the ArtTech Forum 2023 Prize.</p>
              </div>
              <figure class="design-case-media">
                <img
                  src="/design/holon-products.png"
                  width="2008"
                  height="1022"
                  alt="Holon product visuals"
                  class="design-case-image"
                />
              </figure>
              <div class="design-case-video-pair">
                  <div class="design-case-video">
                    <YouTube
                      id="AUBEsPSuHws"
                      title="Multimodal Commuting (public artwork proposal, 2023)"
                      aspect="16:9"
                    />
                  <p class="design-case-video-caption">Multimodal Commuting (public artwork proposal, 2023)</p>
                </div>
                <div class="design-case-video">
                  <YouTube id="XPGUVc10iaI" title="Holon - Music from Movement" aspect="16:9" />
                  <p class="design-case-video-caption">Holon - Music from Movement</p>
                </div>
              </div>
            </section>
            <section class="design-case-segment design-case-segment--holonist">
              <div class="design-case-header--holonist">
                <div class="prose-ove design-case-copy--holonist">
                  <h4 class="text-lg mb-2">Holon.ist</h4>
                  <p>Holon.ist is the companion app to Holon and an open-world interactive music platform for emergent, mobile, and data-driven sonic experiences. It features sensor data mapping to OSC and MIDI messages, including from wearables like Apple Watch and Airpods, Movesense smart sensors and more.</p>
                  <p class="design-case-paragraph-gap design-case-paragraph-gap--holonist">The Holonic workflow reads incoming OSC, communicates with external users, devices, or services through our JavaScript sandbox, which processes and translates this data into OSM or MIDI. Holonic Systems' deep integration with standard tools, protocols and formats reveals possibilities of interactions that go beyond sonification and sound design to composition and sociomusicology and biomusicology.</p>
                  <p class="design-case-paragraph-gap design-case-paragraph-gap--holonist">Since its launch in 2019, Holon.ist has been used successfully by hundreds, if not thousands, of professional artists around the world in productions ranging from personal experiments to large-scale productions that are highly musical, theatrical, choreographic, and therapeutic. The Holon.ist mobile app, and its related plugins and services, have been central to collaborations with artists, enthusiasts and corporate clients and partners like Finnish sports technology manufacturer Suunto/Movesense and Native Instruments, Holonic Systems participation in the Bose AR beta for developers, and the partnership with mifki, the developers of miRack.</p>
                  <p class="design-case-paragraph-gap design-case-paragraph-gap--holonist">The latest Holonic component; Kaiseki, is a programmatically (OSC) controlled, tempo-synced, 8 track hot-swappable multisampler with pitch shifting and time stretching, for cloud-based structured audio and semantic music playback. Kaiseki was developed by Voxglitch and Holonic Systems to support Telharmonium Labs' mission to enable evolutionary development of any musical form. With Kaiseki, samples can be selected and loaded dynamically from live inputs like location, movement, and biometric data. The Holon.ist preset can be shared to the Holon app with the corresponding miRack patch as a very small file.</p>
                </div>
                <figure class="design-case-media design-case-media--kaiseki design-case-media--panel">
                  <img
                    src="/design/kaiseki.jpeg"
                    width="1536"
                    height="2048"
                    alt="Kaiseki multisampler interface and workflow image"
                    class="design-case-image design-case-image--kaiseki"
                  />
                </figure>
              </div>
              <div class="design-case-media-pair">
                <div class="design-case-video">
                  <YouTube
                    id="0OfQKiKl2Mc"
                    title="Dance performance by Anna Serra at Hangar.org (Barcelona, 2019)"
                    aspect="16:9"
                  />
                  <p class="design-case-video-caption">Dance performance by Anna Serra at Hangar.org (Barcelona, 2019)</p>
                </div>
                <figure class="design-case-media design-case-media--holonist-integrations">
                  <img
                    src="/design/holonist-integrations.jpg"
                    width="1080"
                    height="567"
                    alt="Holon.ist integrations and interface image"
                    class="design-case-image"
                  />
                  <figcaption class="design-case-figure-caption design-case-figure-caption--align-right">Holon.ist integrations</figcaption>
                </figure>
              </div>
              <figure class="design-case-media design-case-media--below">
                <img
                  src="/design/holonist-screens.png"
                  width="1536"
                  height="1024"
                  alt="Holon.ist screen set and interaction views"
                  class="design-case-image"
                />
              </figure>
            </section>
          </article>

          <article class="design-case-card design-case-card--jean-monnet">
            <div class="prose-ove">
              <h3 class="text-xl mb-2">EL-TRAN</h3>
              <h4 class="text-lg mb-2 design-case-subtitle">Academy of Finland/University of Tampere, Jean Monnet Centre for Excellence.</h4>
              <p>This project combined design, research, and visual communication through cartographic and geopolitical material developed for institutional use. It included roundtable documentation, video interviews, and editorially structured visual material. It sits within an earlier body of work in which mapping, information structure, and editorial clarity were central design concerns.</p>
            </div>
            <figure class="design-case-media design-case-media--below design-case-media--flush">
              <div class="design-case-media-triptych">
                <img
                  src="/design/jeanmonnet-uta-1.jpg"
                  width="1030"
                  height="1030"
                  alt="University of Tampere Jean Monnet Centre for Excellence panel one"
                  class="design-case-image"
                />
                <img
                  src="/design/jeanmonnet-uta-2.jpg"
                  width="1030"
                  height="1030"
                  alt="University of Tampere Jean Monnet Centre for Excellence panel two"
                  class="design-case-image"
                />
                <img
                  src="/design/jeanmonnet-uta-3.jpg"
                  width="1030"
                  height="1030"
                  alt="University of Tampere Jean Monnet Centre for Excellence panel three"
                  class="design-case-image"
                />
              </div>
            </figure>
          </article>

          {bedditWork && (
            <article class="design-case-card design-case-card--beddit">
              <div class="design-case-header design-case-header--beddit">
                <div class="prose-ove">
                  <h3 class="text-xl mb-2">
                    <a href="/works/beddit" class="design-case-link">Beddit: Sleep sonification and musical alarms</a>
                  </h3>
                  {bedditLeadIntro && <p>{bedditLeadIntro}</p>}
                  {bedditLeadFollowUp && <p class="design-case-beddit-follow-up">{bedditLeadFollowUp}</p>}
                </div>
                <figure class="design-case-media design-case-media--beddit-device">
                  <img
                    src="/works/beddit/beddit-device.png"
                    width="944"
                    height="580"
                    alt="Beddit device documentation image"
                    class="design-case-image design-case-image--contain"
                  />
                </figure>
              </div>
              <div class="design-case-beddit-media">
                <figure class="design-case-media design-case-media--beddit-portrait">
                  <img
                    src="/works/beddit/beddit-ove.jpg"
                    width="768"
                    height="776"
                    alt="Ove Holmqvist during Beddit-related work"
                    class="design-case-image design-case-image--beddit-photo"
                  />
                </figure>
                <figure class="design-case-media design-case-media--beddit-hero">
                  <img
                    src="/works/beddit/beddit-slush.jpg"
                    width="1729"
                    height="1601"
                    alt="Beddit interactive booth presented at Slush 2015"
                    class="design-case-image design-case-image--beddit-photo"
                  />
                </figure>
              </div>
              {bedditTailParagraphs.length > 0 && (
                <div class="prose-ove design-case-copy--beddit-tail">
                  {bedditTailParagraphs.map((paragraph) => (
                    <p>{paragraph}</p>
                  ))}
                </div>
              )}
            </article>
          )}
        </div>
      </section>

      <section id="research-development-education" class="research-section card works-section works-section--full">
        <div id="research-education" aria-hidden="true"></div>
        <div class="prose-ove research-section-intro">
          <h2 class="text-2xl mb-3">Research, Development and Education</h2>
          <p class="max-w-4xl">Scientific research and artistic studies remain foundational in my work. I approach problems from a systemic and evolutionary perspective, and this has informed consulting, technical development, workshops, and collaborative research for startups, academic institutions, established hardware and software vendors, event organisers, and experiential agencies.</p>
        </div>

        <div class="research-support-grid research-support-grid--intro">
          <figure class="research-support-card">
            <div class="research-support-media">
              <img
                src="/about/img-4412.jpg"
                width="4032"
                height="3024"
                alt="Participants gathered outdoors during a New Works XR activity"
                loading="lazy"
                decoding="async"
                class="research-support-image research-support-image--new-works"
              />
            </div>
            <figcaption>New Works XR, Vancouver</figcaption>
          </figure>
          <figure class="research-support-card">
            <div class="research-support-media">
              <img
                src="/research/musical-instrument-museum.jpg"
                width="2025"
                height="1350"
                alt="Workshop participants testing instruments in a museum setting"
                loading="lazy"
                decoding="async"
                class="research-support-image research-support-image--mim"
              />
            </div>
            <figcaption>Musical Instruments Museum, Brussels</figcaption>
          </figure>
        </div>

        <div class="research-entry-grid">
          <article class="research-entry research-entry--media">
            <div class="prose-ove">
              <h3 class="text-xl mb-2">QMUL / Centre for Digital Music</h3>
              <p>Holonic Systems is an industrial partner to Queen Mary University London's Centre For Digital Music, and I have in this capacity participated in C4D's AI+Music doctoral program as a mentor.</p>
              <p class="research-entry-paragraph-gap">Since 2019, I have tutored PhD and Masters students in researching and developing Ubiquitous Music experiences, which are often centred around functional music, a concept we spearheaded and helped commercialise.</p>
            </div>
            <figure class="research-entry-figure">
              <img
                src="/research/qmul-C4D-lab.jpg"
                width="4032"
                height="3024"
                alt="Queen Mary University of London Centre for Digital Music lab"
