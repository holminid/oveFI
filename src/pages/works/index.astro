<script is:inline define:vars={{ defaultSlug }}>
  const panels = Array.from(document.querySelectorAll('[data-work-panel]'));
  const links = Array.from(document.querySelectorAll('[data-work-link]'));
  const selectedWorksAnchor = document.querySelector('.works-section-heading--selected');
  const validSlugs = new Set(panels.map((panel) => panel.dataset.slug).filter(Boolean));
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  const resolveSlug = () => {
    const url = new URL(window.location.href);
    const requested = url.searchParams.get('w');

    if (requested && validSlugs.has(requested)) {
      return requested;
    }

    if (validSlugs.has(defaultSlug)) {
      if (requested) {
        url.searchParams.set('w', defaultSlug);
        window.history.replaceState({}, '', `${url.pathname}?${url.searchParams.toString()}`);
      }

      return defaultSlug;
    }

    return panels[0]?.dataset.slug ?? '';
  };

  const syncSelection = () => {
    const selectedSlug = resolveSlug();

    panels.forEach((panel) => {
      const isActive = panel.dataset.slug === selectedSlug;
      panel.hidden = !isActive;
      panel.classList.toggle('is-active', isActive);
    });

    links.forEach((link) => {
      const isActive = link.dataset.slug === selectedSlug;
      link.classList.toggle('is-active', isActive);

      if (isActive) {
        link.setAttribute('aria-current', 'true');
      } else {
        link.removeAttribute('aria-current');
      }
    });
  };

  const scrollSelectedWorksIntoView = () => {
    selectedWorksAnchor?.scrollIntoView({
      block: 'start',
      behavior: prefersReducedMotion.matches ? 'auto' : 'smooth'
    });
  };

  links.forEach((link) => {
    link.addEventListener('click', (event) => {
      const href = link.getAttribute('href');

      if (!href) {
        return;
      }

      event.preventDefault();
      window.history.pushState({}, '', href);
      syncSelection();
      requestAnimationFrame(scrollSelectedWorksIntoView);
    });
  });

  window.addEventListener('popstate', syncSelection);
  syncSelection();
</script>

